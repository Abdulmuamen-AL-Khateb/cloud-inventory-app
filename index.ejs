<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Cloud Inventory — Electronics</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, sans-serif; background: #f4f6f9; color: #333; }

    header {
      background: #1a1a2e; color: #fff;
      padding: 16px 32px;
      display: flex; justify-content: space-between; align-items: center;
    }
    header h1 { font-size: 1.4rem; }
    .pod-info { font-size: 0.8rem; color: #aaa; text-align: right; }

    .container { max-width: 1200px; margin: 24px auto; padding: 0 24px; }

    .filter-bar { margin-bottom: 16px; }
    .filter-bar select {
      padding: 8px 12px; border-radius: 6px;
      border: 1px solid #ccc; font-size: 0.95rem;
    }

    table {
      width: 100%; border-collapse: collapse;
      background: #fff; border-radius: 8px;
      overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    th {
      background: #1a1a2e; color: #fff;
      padding: 12px 16px; text-align: left; font-size: 0.9rem;
    }
    td { padding: 11px 16px; border-bottom: 1px solid #eee; font-size: 0.9rem; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #f0f4ff; }

    .badge {
      display: inline-block; padding: 3px 10px;
      border-radius: 12px; font-size: 0.78rem; font-weight: bold;
    }
    .badge.in_stock { background: #d4f7e0; color: #1a7a40; }
    .badge.low      { background: #fff3cd; color: #856404; }
    .badge.out      { background: #fde8e8; color: #a61c1c; }

    .error { color: #a61c1c; background: #fde8e8; padding: 12px 20px; border-radius: 6px; margin-bottom: 16px; }

    footer {
      text-align: center; padding: 20px;
      font-size: 0.8rem; color: #999; margin-top: 32px;
    }
  </style>
</head>
<body>

<header>
  <h1>📦 Cloud Inventory — Electronics & Parts</h1>
  <div class="pod-info">
    Served by Pod: <strong><%= podName %></strong><br/>
    IP: <strong><%= podIp %></strong>
  </div>
</header>

<div class="container">

  <% if (dbError) { %>
    <p class="error">⚠️ <%= dbError %></p>
  <% } %>

  <!-- Category filter -->
  <div class="filter-bar">
    <form method="GET" action="/">
      <select name="category" onchange="this.form.submit()">
        <option value="">All Categories</option>
        <% categories.forEach(cat => { %>
          <option value="<%= cat %>" <%= selected === cat ? 'selected' : '' %>><%= cat %></option>
        <% }) %>
      </select>
    </form>
  </div>

  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Product Name</th>
        <th>Category</th>
        <th>Supplier</th>
        <th>Quantity</th>
        <th>Price (USD)</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% if (inventory.length === 0) { %>
        <tr><td colspan="7" style="text-align:center; color:#999;">No products found.</td></tr>
      <% } else { %>
        <% inventory.forEach(item => { %>
          <tr>
            <td><%= item.id %></td>
            <td><strong><%= item.name %></strong></td>
            <td><%= item.category %></td>
            <td><%= item.supplier %></td>
            <td><%= item.quantity %></td>
            <td>$<%= Number(item.price).toFixed(2) %></td>
            <td><span class="badge <%= item.stock_status %>"><%= item.stock_status.replace('_',' ') %></span></td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>

</div>

<footer>
  Cloud-Based Inventory Management System &nbsp;|&nbsp;
  Pod: <%= podName %> &nbsp;|&nbsp; IP: <%= podIp %>
</footer>

</body>
</html>
